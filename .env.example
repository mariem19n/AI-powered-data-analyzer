# ============================================================
# Variables d'environnement — TEMPLATE
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=analyzer_db
POSTGRES_USER=analyzer
POSTGRES_PASSWORD=<your_password>
DATABASE_URL=postgresql+asyncpg://analyzer:<your_password>@postgres:5432/analyzer_db

# --- Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<your_password>

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Cache TTL (en secondes) ---
CACHE_TTL_TRANSACTIONAL=3600         # 1h — données transactionnelles
CACHE_TTL_HISTORICAL=86400           # 24h — données historiques
CACHE_TTL_EXECUTION_PLAN=86400       # 24h — plans d'exécution
CACHE_TTL_SESSION=7200               # 2h — sessions conversationnelles

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=30             # Requêtes max par utilisateur par minute

# --- API ---
SECRET_KEY=<generate-a-strong-key>
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
